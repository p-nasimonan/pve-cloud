---
import type { Locale } from "../../i18n/index.ts";
import { useTranslations, LOCALES } from "../../i18n/index.ts";
import { css, cx } from "../../../styled-system/css";

interface Props {
  locale: Locale;
  username: string;
  role: string;
  currentPath: string;
}

const { locale, username, role, currentPath } = Astro.props;
const t = useTranslations(locale);

const localeLabels: Record<Locale, string> = { ja: "日本語", en: "English" };

function localePath(target: Locale): string {
  if (target === "ja") return currentPath.replace(/^\/en/, "") || "/";
  return currentPath.startsWith("/en") ? currentPath : `/en${currentPath}`;
}

const topbar = css({
  height: "topbar",
  bg: "topbar-bg",
  position: "sticky",
  top: "0",
  zIndex: "50",
  display: "flex",
  alignItems: "center",
  justifyContent: "flex-end",
  px: "5",
  gap: "4",
  borderBottom: "1px solid {colors.topbar-border}",
  flexShrink: "0",
});

const langSwitcher = css({
  display: "flex",
  gap: "1",
});

const langBtn = css({
  px: "2",
  py: "0.5",
  borderRadius: "sm",
  fontSize: "0.8rem",
  color: "topbar-text",
  textDecoration: "none",
  transition: "background 0.15s",
  _hover: { bg: "nav-item-hover", color: "text-inverse", textDecoration: "none" },
});

const langBtnActive = css({
  bg: "nav-item-hover",
  color: "text-inverse",
  fontWeight: "600",
});

const separator = css({
  width: "1px",
  height: "20px",
  bg: "nav-divider",
});

const userSection = css({
  display: "flex",
  alignItems: "center",
  gap: "2.5",
});

const usernameText = css({
  fontSize: "0.875rem",
  color: "topbar-text",
});

const adminBadge = css({
  fontSize: "0.68rem",
  fontWeight: "700",
  px: "1.5",
  py: "0.5",
  bg: "brand",
  color: "text-inverse",
  borderRadius: "full",
  textTransform: "uppercase",
  letterSpacing: "0.05em",
});

const logoutBtn = css({
  fontSize: "0.8rem",
  color: "topbar-text",
  bg: "transparent",
  border: "1px solid {colors.nav-divider}",
  px: "2.5",
  py: "1",
  borderRadius: "sm",
  cursor: "pointer",
  transition: "border-color 0.15s, color 0.15s",
  _hover: { borderColor: "topbar-text", color: "text-inverse" },
});
---

<header class={topbar}>
  <div class={langSwitcher}>
    {LOCALES.map((loc) => (
      <a
        href={localePath(loc)}
        class={cx(langBtn, loc === locale ? langBtnActive : "")}
        lang={loc}
      >
        {localeLabels[loc]}
      </a>
    ))}
  </div>

  <div class={separator}></div>

  <div class={userSection}>
    <span class={usernameText}>{username}</span>
    {role === "admin" && <span class={adminBadge}>admin</span>}
    <button class={logoutBtn} id="topbar-logout">{t("nav.logout")}</button>
  </div>
</header>

<script>
  document.getElementById("topbar-logout")?.addEventListener("click", async () => {
    await fetch("/api/auth/logout", { method: "POST", credentials: "include" });
    window.location.href = "/login";
  });
</script>
