---
import { css } from "../../../styled-system/css";

interface Props {
  title: string;
}

const { title } = Astro.props;

const header = css({
  display: "flex",
  justifyContent: "space-between",
  alignItems: "center",
  mb: "5",
});

const titleStyle = css({
  fontSize: "1.375rem",
  fontWeight: "700",
  color: "text-primary",
  lineHeight: "1.3",
});
---

<div class={header}>
  <h1 class={titleStyle}>{title}</h1>
  <slot name="actions" />
</div>
